{
  "npcs": [
    {
      "id": "mayor",
      "name": "Prefeito Aldric",
      "position": { "x": -3, "y": 0, "z": -4 },
      "modelPlaceholder": { "type": "capsule", "color": "#FFD700" },
      "dialogTree": {
        "root": "root",
        "nodes": {
          "root": {
            "text": "Saudações, aventureiro! Nossa vila precisa de ajuda.",
            "options": [
              { "text": "O que está acontecendo?", "next": "problema" },
              {
                "text": "[Missão] Aceitar caçada aos slimes",
                "next": "aceitar_slimes",
                "condition": { "type": "questNotStarted", "questId": "quest_slimes" },
                "action":    { "type": "offerQuest",      "questId": "quest_slimes" }
              },
              {
                "text": "[Entregar] Já eliminei os slimes!",
                "next": "slimes_completo",
                "condition": { "type": "questCompletable", "questId": "quest_slimes" },
                "action":    { "type": "completeQuest",    "questId": "quest_slimes" }
              },
              {
                "text": "Ainda estou caçando os slimes.",
                "next": "end",
                "condition": { "type": "questActive", "questId": "quest_slimes" }
              },
              {
                "text": "[Missão] Preciso de um pacote entregue",
                "next": "aceitar_entrega",
                "condition": { "type": "questNotStarted", "questId": "quest_delivery" },
                "action":    { "type": "offerQuest",      "questId": "quest_delivery" }
              },
              { "text": "Até logo.", "next": "end" }
            ]
          },
          "problema": {
            "text": "Slimes invadiram os arredores! E preciso de um pacote urgente no ferreiro. Pode ajudar?",
            "options": [
              { "text": "Voltarei ao menu anterior.", "next": "root" }
            ]
          },
          "aceitar_slimes": {
            "text": "Excelente! Elimine 5 slimes nos arredores e volte a mim. Boa sorte!",
            "options": [
              { "text": "Pode contar comigo.", "next": "end" }
            ]
          },
          "slimes_completo": {
            "text": "Fantástico! A vila está mais segura graças a você. Aqui está sua recompensa, aventureiro!",
            "options": [
              { "text": "Obrigado, prefeito!", "next": "end" }
            ]
          },
          "aceitar_entrega": {
            "text": "Preciso que este pacote chegue ao ferreiro com urgência. Você pode fazer isso?",
            "options": [
              { "text": "Sim, levarei o pacote.", "next": "end" },
              { "text": "Agora não posso.", "next": "end" }
            ]
          }
        }
      }
    },
    {
      "id": "blacksmith",
      "name": "Ferreiro Bram",
      "position": { "x": 4, "y": 0, "z": -3 },
      "modelPlaceholder": { "type": "capsule", "color": "#FFD700" },
      "dialogTree": {
        "root": "root",
        "nodes": {
          "root": {
            "text": "Oi! Ocupado com as forjas agora. Tem algo pra mim?",
            "options": [
              {
                "text": "[Entregar] Aqui está o pacote do prefeito.",
                "next": "receber_pacote",
                "condition": { "type": "questCompletable", "questId": "quest_delivery" },
                "action":    { "type": "completeQuest",    "questId": "quest_delivery" }
              },
              { "text": "Só vim dar uma olhada.", "next": "end" }
            ]
          },
          "receber_pacote": {
            "text": "Ah, finalmente chegou! Estava esperando por isso. Aqui está sua recompensa pelo trabalho.",
            "options": [
              { "text": "Disponha, ferreiro!", "next": "end" }
            ]
          }
        }
      }
    },
    {
      "id": "merchant",
      "name": "Comerciante Lyra",
      "position": { "x": 0, "y": 0, "z": -6 },
      "modelPlaceholder": { "type": "capsule", "color": "#FFD700" },
      "dialogTree": {
        "root": "greet",
        "nodes": {
          "greet": {
            "text": "Boa tarde! Lyra's Mercadorias, o melhor preço da cidade — aliás, o único preço da cidade! O que você precisa?",
            "options": [
              { "text": "O que você tem para vender?", "next": "wares" },
              { "text": "Como estão os negócios?", "next": "business" },
              { "text": "Adeus.", "next": "end" }
            ]
          },
          "wares": {
            "text": "Poções de vida, ervas medicinais, pergaminhos... Tudo o que o aventureiro moderno precisa para sobreviver! Meu inventário completo abre em breve.",
            "options": [
              { "text": "Aguardo a abertura.", "next": "thanks" },
              { "text": "Adeus.", "next": "end" }
            ]
          },
          "business": {
            "text": "Péssimos, para ser honesta. Com monstros bloqueando as estradas, as caravanas pararam de chegar. Se isso continuar, vou à falência.",
            "options": [
              { "text": "Espero que melhore.", "next": "thanks" },
              { "text": "Adeus.", "next": "end" }
            ]
          },
          "thanks": {
            "text": "Volte sempre! E se encontrar itens valiosos por aí, eu compro — pagando bem!",
            "options": [
              { "text": "Adeus.", "next": "end" }
            ]
          }
        }
      }
    },
    {
      "id": "priest",
      "name": "Padre Silas",
      "position": { "x": -5, "y": 0, "z": 2 },
      "modelPlaceholder": { "type": "capsule", "color": "#FFD700" },
      "dialogTree": {
        "root": "greet",
        "nodes": {
          "greet": {
            "text": "A luz de Odin guie seus passos, filho. Estou aqui para curar corpos e almas. Você veio buscar conforto ou orientação?",
            "options": [
              { "text": "Pode me curar?", "next": "heal" },
              { "text": "O que é este lugar?", "next": "lore" },
              { "text": "Adeus, Padre.", "next": "end" }
            ]
          },
          "heal": {
            "text": "A cura divina ainda não me foi concedida neste plano... mas ore comigo e sua força se renovará. Em breve poderei fazer mais por você.",
            "options": [
              { "text": "Obrigado mesmo assim.", "next": "blessing" },
              { "text": "Adeus.", "next": "end" }
            ]
          },
          "lore": {
            "text": "Lumie foi construída sobre as ruínas de um antigo templo. Dizem que poder dorme sob a terra aqui. Talvez por isso os monstros circulam tanto.",
            "options": [
              { "text": "Interessante...", "next": "blessing" },
              { "text": "Adeus.", "next": "end" }
            ]
          },
          "blessing": {
            "text": "Que Odin proteja sua jornada. Leve esta bênção: que cada passo seu seja firme e cada golpe, certeiro.",
            "options": [
              { "text": "Adeus, Padre.", "next": "end" }
            ]
          }
        }
      }
    },
    {
      "id": "guard",
      "name": "Guarda Torren",
      "position": { "x": 3, "y": 0, "z": 3 },
      "modelPlaceholder": { "type": "capsule", "color": "#FFD700" },
      "dialogTree": {
        "root": "root",
        "nodes": {
          "root": {
            "text": "Alto aí! Ah, é você. Preciso de alguém de confiança para uma tarefa.",
            "options": [
              {
                "text": "[Missão] Qual tarefa?",
                "next": "oferecer_exploracao",
                "condition": { "type": "questNotStarted", "questId": "quest_forest" },
                "action":    { "type": "offerQuest",      "questId": "quest_forest" }
              },
              {
                "text": "[Entregar] Já verifiquei a floresta, está tudo certo!",
                "next": "exploracao_completa",
                "condition": { "type": "questCompletable", "questId": "quest_forest" },
                "action":    { "type": "completeQuest",    "questId": "quest_forest" }
              },
              { "text": "Nada por agora.", "next": "end" }
            ]
          },
          "oferecer_exploracao": {
            "text": "Preciso que você verifique o ponto de observação na floresta a nordeste, perto de (40, 40). Confirme que está tudo seguro.",
            "options": [
              { "text": "Entendido. Vou verificar.", "next": "end" }
            ]
          },
          "exploracao_completa": {
            "text": "Excelente trabalho! O ponto estava seguro, como esperávamos. A vila agradece sua coragem!",
            "options": [
              { "text": "Sempre às ordens, guarda.", "next": "end" }
            ]
          }
        }
      }
    },
