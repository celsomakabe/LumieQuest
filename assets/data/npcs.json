                "action": { "type": "shop" }
              },
              {
                "text": "Adeus.",
                "next": "end"
              }
            ]
          },
          "wares": {
            "text": "Poções de vida, ervas medicinais, pergaminhos... Tudo o que o aventureiro moderno precisa para sobreviver! Meu inventário completo abre em breve.",
            "options": [
              {
                "text": "Aguardo a abertura.",
                "next": "thanks"
              },
              {
                "text": "Adeus.",
                "next": "end"
              }
            ]
          },
          "business": {
            "text": "Péssimos, para ser honesta. Com monstros bloqueando as estradas, as caravanas pararam de chegar. Se isso continuar, vou à falência.",
            "options": [
              {
                "text": "Espero que melhore.",
                "next": "thanks"
              },
              {
                "text": "Adeus.",
                "next": "end"
              }
            ]
          },
          "thanks": {
            "text": "Volte sempre! E se encontrar itens valiosos por aí, eu compro — pagando bem!",
            "options": [
              {
                "text": "Adeus.",
                "next": "end"
              }
            ]
