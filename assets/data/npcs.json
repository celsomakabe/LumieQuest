                "action":    { "type": "doJobChange",     "jobId": "knight" }
              },
              { "text": "Adeus.", "next": "end" }
            ]
          },
          "already_knight": {
            "text": "Continue treinando, Cavaleiro.",
            "options": [{ "text": "Adeus.", "next": "end" }]
          },
          "aceitar_prova": {
            "text": "Derrote o Orc Warrior nas ruínas e prove sua força. Volte quando terminar.",
            "options": [{ "text": "Pode contar comigo.", "next": "end" }]
          },
          "em_andamento": {
            "text": "Termine a prova antes de continuar.",
            "options": [{ "text": "Voltarei.", "next": "end" }]
          },
          "completar_prova": {
            "text": "Você superou a prova. Está pronto para o juramento.",
            "options": [{ "text": "Estou pronto.", "next": "end" }]
          },
          "confirmar_jobchange": {
            "text": "Que a força guie sua lâmina. Você agora é um Knight!",
            "options": [{ "text": "Obrigado, Mestre.", "next": "end" }]
          }
        }
      }
    },
